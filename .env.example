# Copy to .env and fill in real values. Never commit .env.

# --- Core ---
SENTINELAI_ENVIRONMENT=development
SENTINELAI_DEBUG=true

# --- Postgres ---
SENTINELAI_DATABASE_URL=postgresql+asyncpg://sentinelai:sentinelai@postgres:5432/sentinelai

# --- Redis / Cache ---
SENTINELAI_REDIS_URL=redis://redis:6379/0
SENTINELAI_LANGCACHE_MODE=local          # "local" (self-hosted Redis Stack) or "managed" (Redis LangCache)
# Only needed if SENTINELAI_LANGCACHE_MODE=managed:
SENTINELAI_LANGCACHE_URL=https://aws-us-east-1.langcache.redis.io
SENTINELAI_LANGCACHE_CACHE_ID=
SENTINELAI_LANGCACHE_API_KEY=

# --- ChromaDB ---
SENTINELAI_CHROMA_HOST=chromadb
SENTINELAI_CHROMA_PORT=8000
SENTINELAI_CHROMA_COLLECTION=sentinelai_documents

# --- RabbitMQ / Celery ---
SENTINELAI_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
SENTINELAI_CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Embeddings ---
SENTINELAI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SENTINELAI_EMBEDDING_DIM=384

# --- Groq ---
SENTINELAI_GROQ_API_KEY=your-groq-api-key-here
SENTINELAI_GROQ_MODEL_FAST=llama-3.1-8b-instant
SENTINELAI_GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# --- Observability (optional — leave blank to disable Langfuse tracing) ---
SENTINELAI_LANGFUSE_PUBLIC_KEY=
SENTINELAI_LANGFUSE_SECRET_KEY=
SENTINELAI_LANGFUSE_HOST=https://cloud.langfuse.com

# --- Cache TTL overrides (all optional, seconds) ---
SENTINELAI_TTL_SEMANTIC_RESPONSE=3600
SENTINELAI_TTL_PROMPT=1800
SENTINELAI_TTL_EMBEDDING=86400
SENTINELAI_TTL_RETRIEVAL=900
SENTINELAI_TTL_RERANKING=900
SENTINELAI_TTL_EVALUATION=604800
SENTINELAI_TTL_METADATA=3600
SENTINELAI_TTL_RESPONSE_REPAIR=1800
SENTINELAI_TTL_GUARDRAIL_DECISION=3600
SENTINELAI_TTL_MODEL_ROUTING=300
SENTINELAI_TTL_CONFIGURATION=60
